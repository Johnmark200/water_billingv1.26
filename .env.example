# Copy this file to .env and replace the placeholder values with your live credentials.

# Django Core Settings
DJANGO_SECRET_KEY=replace-this-with-a-secret-key
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,localhost,127.0.0.1

# Database Configuration (Render PostgreSQL)
DB_ENGINE=postgresql
DB_NAME=waterbilling
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=your-database-host
DB_PORT=5432

# Alternative: Use SQLite for development
# USE_SQLITE=True

# Alternative: Use MySQL
# DB_ENGINE=mysql
# DB_NAME=waterbilling_v1.26
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306

# Email Configuration
DEFAULT_FROM_NAME=Tabuan Waterbilling

# Real email delivery (SendGrid)
EMAIL_DELIVERY_PROVIDER=sendgrid
DEFAULT_FROM_EMAIL=verified-sender@example.com
SENDGRID_FROM_EMAIL=verified-sender@example.com
SENDGRID_FROM_NAME=Water Billing System
SENDGRID_API_KEY=SG.replace-with-your-sendgrid-api-key

# Optional SMTP alternative if you prefer a real mailbox instead of SendGrid
# EMAIL_DELIVERY_PROVIDER=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=true

# SMS Configuration (SMS API PH)
SMS_DELIVERY_PROVIDER=sms_api_ph
SMS_API_TIMEOUT=10
SMS_API_RETRY_ATTEMPTS=2
SMS_API_PH_ENDPOINT=https://dashboard.philsms.com/api/v3/
SMS_API_PH_API_KEY=your-sms-api-key
SMS_API_PH_RECIPIENT_FIELD=recipient
SMS_API_PH_MESSAGE_FIELD=message
SMS_API_PH_SENDER_ID=TABUANWATER
SMS_API_PH_MESSAGE_TYPE=plain

# Alternative SMS delivery (Twilio)
# SMS_DELIVERY_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=replace-with-your-twilio-api-key-secret
# TWILIO_PHONE_NUMBER=+15551234567

# Payment Configuration (PayMongo)
PAYMONGO_SECRET_KEY=your-paymongo-secret-key

# Google OAuth (if using Google login)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_PATH=/login/google/callback/
