# Copy this file to .env and replace the placeholder values with your live credentials.

DJANGO_SECRET_KEY=replace-this-with-a-secret-key

# Real email delivery
EMAIL_DELIVERY_PROVIDER=sendgrid
DEFAULT_FROM_EMAIL=verified-sender@example.com
SENDGRID_FROM_EMAIL=verified-sender@example.com
SENDGRID_FROM_NAME=Water Billing System
SENDGRID_API_KEY=SG.replace-with-your-sendgrid-api-key

# Optional SMTP alternative if you prefer a real mailbox instead of SendGrid
# EMAIL_DELIVERY_PROVIDER=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=true

# Real SMS delivery
SMS_DELIVERY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option 1: Account SID + Auth Token
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
# Option 2: Account SID + API Key SID + API Key Secret
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-with-your-twilio-api-key-secret
TWILIO_PHONE_NUMBER=+15551234567
